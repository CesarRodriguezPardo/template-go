server {
    server_name boletas.test-citiaps.cl;
    access_log /var/log/nginx/boletas_access.log;
    error_log /var/log/nginx/boletas_error.log;

    location /api/v1 {
        proxy_pass http://127.0.0.1:1809;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /panel {
        proxy_pass http://127.0.0.1:2009;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
    location / {
        proxy_pass http://127.0.0.1:1909;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/boletas.test-citiaps.cl/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/boletas.test-citiaps.cl/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}
server {
    if ($host = boletas.test-citiaps.cl) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    server_name boletas.test-citiaps.cl;
    return 404; # managed by Certbot


}