# db config
# postgres
DB_USER_POSTGRES=postgres
DB_PASS_POSTGRES=pass_postges
DB_HOST_POSTGRES=postgres
DB_PORT_POSTGRES=5432
DB_NAME_POSTGRES=nombre_db

# PORT
PORT=8000

# GIN
GIN_MODE=release # release or debug
# JWT ALGORITHM
SIGNING_ALG=RS256

# JWT SYMMETRIC
# JWT_KEY=example comentado ya que se esta usando uno asimetrico

# JWT
PRIVATE_KEY_PATH=/app/keys/priv.pem
PUBLIC_KEY_PATH=/app/keys/pub.pem

# SAVE FILES
STORAGE_PATH=app/storage

# MAILER CONFIG
EMAIL_DIR=tu-email@gmail.com
EMAIL_PASS=tu-password-de-aplicacion
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# CORS
CORS_URLS=http://localhost:8000

